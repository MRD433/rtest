{
  "manifest_version": 3,
  "name": "YouTube Dark Mode+",
  "version": "1.0.0",
  "description": "",
  "permissions": [],
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "css": [
        "styles.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
